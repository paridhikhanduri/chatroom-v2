{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "chat-room-server",
  "version": "0.1.0",
  "identifier": "com.chatroom.app",
  "build": {
  "frontendDist": "../public/",
  "beforeBuildCommand": "npm run build:server-binary"
},
  "app": {
    "windows": [
      {
        "title": "Tauri",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/chatroom-server"],
    "resources": ["resources/scenarios.json", "resources/public"],

    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
